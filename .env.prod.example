# =============================================================================
# Production environment template
# Copy to .env and fill in real values before deploying.
#   cp .env.prod.example .env
# .env is gitignored — never commit it.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Used by the api service inside docker-compose.prod.yml.
# The hostname "postgres" resolves to the postgres container via Docker DNS.
DATABASE_URL=postgresql://backtesting:CHANGE_ME@postgres:5432/backtesting

# Password for the postgres container itself (must match DATABASE_URL above)
POSTGRES_PASSWORD=CHANGE_ME

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ── Nginx (public-facing port) ────────────────────────────────────────────────
# Change to 443 when TLS is configured via certbot.
PUBLIC_PORT=80

# ── Optional: Telegram alerts ─────────────────────────────────────────────────
# Create a bot via @BotFather, then get the chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
