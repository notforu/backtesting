{
  "name": "backtesting",
  "version": "1.0.0",
  "description": "Modular crypto backtesting platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:web": "vite",
    "build": "tsc && (tsc -p tsconfig.strategies.json || true) && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:web": "vitest run --config vitest.config.web.ts",
    "backtest": "tsx src/cli/backtest.ts",
    "quant:validate": "tsx src/cli/quant-validate.ts",
    "quant:backtest": "tsx src/cli/quant-backtest.ts",
    "quant:walk-forward": "tsx src/cli/quant-walk-forward.ts",
    "quant:optimize": "tsx src/cli/quant-optimize.ts",
    "quant:score": "tsx src/cli/quant-score.ts",
    "paper-trade": "tsx scripts/pm-paper-trade.ts",
    "quant:cache-candles": "tsx scripts/cache-candles.ts",
    "paper:seed": "npx tsx scripts/seed-paper-test.ts",
    "config:export": "tsx scripts/export-configs.ts",
    "config:import": "tsx scripts/import-configs.ts",
    "user:create": "tsx scripts/create-user.ts",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'),d=p.join('node_modules','technicalindicators','lib');if(!fs.existsSync(d)){fs.symlinkSync('dist',d)}\""
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0",
    "@tanstack/react-query": "^5.90.20",
    "bcryptjs": "^3.0.3",
    "ccxt": "^4.5.34",
    "fastify": "^5.7.1",
    "jsonwebtoken": "^9.0.3",
    "lightweight-charts": "^5.1.0",
    "pg": "^8.18.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "technicalindicators": "^3.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "private": true
}
