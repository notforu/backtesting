{
  "name": "backtesting",
  "version": "1.0.0",
  "description": "Modular crypto backtesting platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest",
    "backtest": "tsx src/cli/backtest.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@tanstack/react-query": "^5.90.20",
    "better-sqlite3": "^12.6.2",
    "ccxt": "^4.5.34",
    "fastify": "^5.7.1",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "technicalindicators": "^3.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "private": true
}
